# Copia a .env en esta carpeta para desarrollo local (no subir .env al repo).

# Brevo — API (OBLIGATORIO en Render; SMTP puerto 587 esta bloqueado en PaaS)
# Brevo > SMTP y API > Claves API > Generar (empieza por xkeysib-, NO uses la clave xsmtpsib de SMTP)
BREVO_API_KEY=xkeysib_tu_clave_api_aqui

# Remitente verificado en Brevo (Senders). NO uses acc126001@smtp-brevo.com como EMAIL_FROM.
EMAIL_FROM=tu_correo@tudominio.com
EMAIL_FROM_NAME=MyAccess

# Brevo SMTP (solo local con MAIL_SMTP_ENABLED=true)
MAIL_SMTP_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=acc126001@smtp-brevo.com
SMTP_PASSWORD=xsmtpsib_tu_clave_smtp_aqui
