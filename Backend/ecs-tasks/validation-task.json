{
  "family": "myaccess-validation-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::048124478038:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::048124478038:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "validation-service",
      "image": "048124478038.dkr.ecr.us-east-2.amazonaws.com/myaccess-validation-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5005,
          "hostPort": 5005,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "5005"
        },
        {
          "name": "DB_HOST",
          "value": "gateway01.us-east-1.prod.aws.tidbcloud.com"
        },
        {
          "name": "DB_PORT",
          "value": "4000"
        }
      ],
      "secrets": [
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:DB_USERNAME::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:DB_PASSWORD::"
        },
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:GEMINI_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/myaccess-validation-service",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
