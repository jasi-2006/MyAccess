{
  "family": "myaccess-user-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::048124478038:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::048124478038:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "user-service",
      "image": "048124478038.dkr.ecr.us-east-2.amazonaws.com/myaccess-user-service:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 9091,
          "hostPort": 9091,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SERVER_PORT",
          "value": "9091"
        },
        {
          "name": "PORT",
          "value": "9091"
        },
        {
          "name": "DB_HOST",
          "value": "gateway01.us-east-1.prod.aws.tidbcloud.com"
        },
        {
          "name": "DB_PORT",
          "value": "4000"
        },
        {
          "name": "USER_DB_URL",
          "value": "jdbc:mysql://gateway01.us-east-1.prod.aws.tidbcloud.com:4000/user_service?sslMode=REQUIRED"
        },
        {
          "name": "AUTH_DB_URL",
          "value": "jdbc:mysql://gateway01.us-east-1.prod.aws.tidbcloud.com:4000/auth_service?sslMode=REQUIRED"
        },
        {
          "name": "JWT_EXPIRATION",
          "value": "1200000"
        },
        {
          "name": "EMAIL_FROM",
          "value": "myaccesssena@gmail.com"
        },
        {
          "name": "MAIL_SMTP_ENABLED",
          "value": "false"
        },
        {
          "name": "APP_VALIDATION_SERVICE_URL",
          "value": "http://validation-service.myaccess.local:5005"
        }
      ],
      "secrets": [
        {
          "name": "DB_USERNAME",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:DB_USERNAME::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:DB_PASSWORD::"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:JWT_SECRET::"
        },
        {
          "name": "BREVO_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-2:048124478038:secret:myaccess/prod/secrets-U3LxGN:BREVO_API_KEY::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/myaccess-user-service",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
